rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---
    function isValidLocation(data) {
      return data.keys().hasAll(['userId', 'lat', 'lng', 'timestamp', 'displayName']) &&
             data.keys().size() == 5 &&
             data.userId == request.auth.uid &&
             data.lat is number &&
             data.lng is number &&
             data.timestamp is string &&
             data.timestamp.size() < 100 &&
             data.displayName is string &&
             data.displayName.size() <= 100;
    }

    // --- Collection Rules ---
    
    // Connection test document
    match /test/connection {
      allow get: if true;
    }

    match /locations/{userId} {
      // Secure List: evaluating resource.data (Pillar 8)
      // Note: For locations, we allow searching others to show them on the map.
      allow list: if isSignedIn(); 
      allow get: if isSignedIn();

      allow create: if isOwner(userId) && isValidLocation(incoming()) && isValidId(userId);
      allow update: if isOwner(userId) && isValidLocation(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['lat', 'lng', 'timestamp', 'displayName']);
    }
  }
}
